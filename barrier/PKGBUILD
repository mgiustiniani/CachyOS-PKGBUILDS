# Maintainer: Mario Giustiniani <mariogiustiniani@gmail.com>

pkgname=barrier
pkgver=2.4.0
pkgrel=1
pkgdesc='Open-source KVM software — share keyboard and mouse between computers'
arch=('x86_64')
url='https://github.com/debauchee/barrier'
license=('GPL-3.0-or-later')
depends=('openssl' 'qt5-base' 'qt5-network' 'glibc' 'gcc-libs' 'avahi' 'libxtst' 'libxrandr' 'libxinerama' 'curl')
makedepends=('cmake' 'gcc' 'make' 'ninja' 'git')
source=('barrier::git+https://github.com/debauchee/barrier.git#tag=v2.4.0')
sha256sums=('SKIP')

prepare() {
    cd "$srcdir"
}

build() {
    cd "$srcdir/barrier"
    cmake -B build \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DBARRIER_BUILD_GUI=ON \
        -DBARRIER_BUILD_INSTALLER=OFF \
        -DBARRIER_BUILD_TESTS=OFF \
        -GNinja
    cmake --build build
}

package() {
    cd "$srcdir/barrier"
    DESTDIR="$pkgdir" cmake --install build
}
